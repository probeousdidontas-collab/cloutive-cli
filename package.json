{
  "name": "cloutive-cli",
  "version": "1.0.0",
  "description": "AWS Infrastructure Analysis CLI Tool - Uses Codebuff AI to generate comprehensive reports",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "cloutive": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@codebuff/sdk": "^0.9.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "aws",
    "cloud",
    "infrastructure",
    "analysis",
    "report",
    "cli",
    "codebuff",
    "ai"
  ],
  "author": "Cloutive",
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  }
}
