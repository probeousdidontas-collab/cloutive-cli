{
  "name": "aws-optimizer",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:convex\" \"npm run dev:web\"",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:convex": "npm run dev --workspace=packages/convex",
    "dev:sandbox": "npm run dev --workspace=apps/sandbox",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
