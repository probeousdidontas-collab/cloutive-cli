{
  "name": "aws-optimizer-sandbox",
  "main": "src/index.ts",
  "compatibility_date": "2024-12-01",
  "compatibility_flags": ["nodejs_compat"],

  // Durable Object bindings for Sandbox
  "durable_objects": {
    "bindings": [
      {
        "name": "Sandbox",
        "class_name": "Sandbox"
      }
    ]
  },

  // Container configuration - builds from local Dockerfile
  "containers": [
    {
      "name": "sandbox",
      "class_name": "Sandbox",
      "image": "./Dockerfile",
      "instance_type": "basic",
      "max_instances": 1
    }
  ],

  // Required migrations for Durable Objects
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Sandbox"]
    }
  ],

  // Production environment configuration
  "env": {
    "production": {
      "name": "aws-optimizer-sandbox-prod",
      "durable_objects": {
        "bindings": [
          {
            "name": "Sandbox",
            "class_name": "Sandbox"
          }
        ]
      },
      // Container scaling for production
      "containers": [
        {
          "name": "sandbox",
          "class_name": "Sandbox",
          "image": "./Dockerfile",
          "instance_type": "basic",
          "max_instances": 5
        }
      ],
      // Set secrets using: wrangler secret put <SECRET_NAME> --env production
      // Required secrets for /claude (Bedrock):
      // - AWS_ACCESS_KEY_ID: IAM user with bedrock:InvokeModel on the locked model
      // - AWS_SECRET_ACCESS_KEY
      // /execute (raw aws CLI) does not use these — it takes per-request creds.
      // Optional secrets for future features:
      // - RATE_LIMIT_API_KEY: API key for rate limiting service
      // - ALLOWED_ORIGINS: Comma-separated list of allowed CORS origins
      "vars": {
        "ENVIRONMENT": "production"
      }
    },
    "staging": {
      "name": "aws-optimizer-sandbox-staging",
      "durable_objects": {
        "bindings": [
          {
            "name": "Sandbox",
            "class_name": "Sandbox"
          }
        ]
      },
      "containers": [
        {
          "name": "sandbox",
          "class_name": "Sandbox",
          "image": "./Dockerfile",
          "instance_type": "basic",
          "max_instances": 15
        }
      ],
      "vars": {
        "ENVIRONMENT": "staging"
      }
    }
  }
}
