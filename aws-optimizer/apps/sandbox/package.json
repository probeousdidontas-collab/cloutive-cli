{
  "name": "@aws-optimizer/sandbox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude 'src/deploy.test.ts'",
    "test:watch": "vitest --exclude 'src/deploy.test.ts'",
    "test:deploy": "vitest run src/deploy.test.ts",
