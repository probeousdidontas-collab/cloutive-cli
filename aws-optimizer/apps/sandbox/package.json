    "deploy:staging": "./deploy.sh staging",
    "deploy:production": "./deploy.sh production"
  },
  "dependencies": {
    "@cloudflare/sandbox": "^0.3.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/node": "^22.15.32",
    "typescript": "^5.7.2",
    "vitest": "^4.0.17",
    "wrangler": "^4.10.0"
  }
}
